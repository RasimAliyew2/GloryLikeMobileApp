<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:model="clr-namespace:MetanetA_MobileApp.Model"
             xmlns:vm="clr-namespace:MetanetA_MobileApp.ViewModels.Sign.SingUp"
             x:Class="MetanetA_MobileApp.View.SignUp.VerifySkillsPage"
             x:Name="Page"
             x:DataType="vm:VerifySkillsViewModel"
             BackgroundColor="#F6F8FC"
             Shell.NavBarIsVisible="False">

    <ScrollView>

        <Grid Padding="10">

            <Border BackgroundColor="#F8FAFD"
                    Stroke="#DCE2EC"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 48"
                    Padding="24,20">

                <VerticalStackLayout Spacing="24">

                    <!-- Steps -->
                    <VerticalStackLayout Spacing="12">

                        <CollectionView ItemsSource="{Binding Steps}"
                                        SelectionMode="None"
                                        HeightRequest="68">

                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal"
                                                   ItemSpacing="22"/>
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="model:IdentityStepModel">

                                    <VerticalStackLayout WidthRequest="58"
                                                         Spacing="6"
                                                         HorizontalOptions="Center">

                                        <Grid WidthRequest="26"
                                              HeightRequest="26"
                                              HorizontalOptions="Center">

                                            <Ellipse Fill="#EEF2F8"/>

                                            <!-- Completed -->
                                            <Ellipse WidthRequest="24"
                                                     HeightRequest="24"
                                                     Fill="#5261C7"
                                                     IsVisible="{Binding IsCompleted}"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center"/>

                                            <Label Text="✓"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   TextColor="White"
                                                   IsVisible="{Binding IsCompleted}"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center"/>

                                            <!-- Active -->
                                            <Ellipse WidthRequest="24"
                                                     HeightRequest="24"
                                                     Fill="#3347B8"
                                                     IsVisible="{Binding IsActive}"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center"/>

                                            <Ellipse WidthRequest="7"
                                                     HeightRequest="7"
                                                     Fill="White"
                                                     IsVisible="{Binding IsActive}"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center"/>
                                        </Grid>

                                        <Label Text="{Binding Title}"
                                               FontSize="12"
                                               TextColor="#071331"
                                               HorizontalTextAlignment="Center"/>

                                        <Label Text="{Binding SubTitle}"
                                               FontSize="10"
                                               TextColor="#3347B8"
                                               HorizontalTextAlignment="Center"/>

                                    </VerticalStackLayout>

                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                        </CollectionView>

                        <BoxView HeightRequest="4"
                                 BackgroundColor="#EEF2F8"
                                 CornerRadius="2"/>

                    </VerticalStackLayout>

                    <!-- Top Actions -->
                    <Grid ColumnDefinitions="*,Auto">

                        <HorizontalStackLayout Spacing="8">

                            <HorizontalStackLayout.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BackCommand}"/>
                            </HorizontalStackLayout.GestureRecognizers>

                            <Label Text="‹"
                                   FontSize="26"
                                   TextColor="#475166"/>

                            <Label Text="Back"
                                   FontSize="14"
                                   TextColor="#475166"/>
                        </HorizontalStackLayout>

                        <Label Grid.Column="1"
                               Text="Skip for now"
                               FontSize="14"
                               TextColor="#475166"
                               TextDecorations="Underline">

                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SkipForNowCommand}"/>
                            </Label.GestureRecognizers>

                        </Label>

                    </Grid>

                    <!-- Title -->
                    <VerticalStackLayout Spacing="10">

                        <Label Text="Verify your skills"
                               FontSize="23"
                               FontAttributes="Bold"
                               TextColor="#071331"/>

                        <Label Text="Add a certificate or employer history to boost credibility."
                               FontSize="16"
                               TextColor="#475166"/>

                    </VerticalStackLayout>

                    <!-- Skills -->
                    <CollectionView ItemsSource="{Binding Skills}"
                                    SelectionMode="None">

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="model:SkillVerifyItemModel">

                                <Border Stroke="#DCE2EC"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 24"
                                        BackgroundColor="White"
                                        Margin="0,0,0,16">

                                    <VerticalStackLayout Spacing="0">

                                        <!-- Header -->
                                        <Grid Padding="16,14"
                                              ColumnDefinitions="*,Auto">

                                            <VerticalStackLayout Spacing="2">

                                                <Label Text="{Binding SkillName}"
                                                       FontSize="17"
                                                       FontAttributes="Bold"
                                                       TextColor="#071331"/>

                                                <Label Text="{Binding CredibilityText}"
                                                       FontSize="14"
                                                       TextColor="#475166"/>

                                            </VerticalStackLayout>

                                            <Label Grid.Column="1"
                                                   Text="⌃"
                                                   FontSize="22"
                                                   TextColor="#071331"
                                                   VerticalOptions="Center"/>

                                        </Grid>

                                        <BoxView HeightRequest="1"
                                                 BackgroundColor="#EEF2F8"/>

                                        <!-- Form -->
                                        <Border BackgroundColor="#F8FAFD"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 22"
                                                Margin="14"
                                                Padding="16">

                                            <VerticalStackLayout Spacing="12">

                                                <Label Text="CERTIFICATE"
                                                       FontSize="13"
                                                       TextColor="#475166"/>

                                                <Entry Placeholder="Certificate name"
                                                       Text="{Binding CertificateName}"
                                                       BackgroundColor="White"
                                                       HeightRequest="46"/>

                                                <Entry Placeholder="Issuer (e.g. Google, Coursera)"
                                                       Text="{Binding Issuer}"
                                                       BackgroundColor="White"
                                                       HeightRequest="46"/>

                                                <Entry Placeholder="Certificate ID / URL"
                                                       BackgroundColor="White"
                                                       HeightRequest="46"/>

                                                <!-- Attach -->
                                                <Border HeightRequest="44"
                                                        Stroke="#AAB5E6"
                                                        StrokeThickness="1"
                                                        StrokeShape="RoundRectangle 22"
                                                        BackgroundColor="Transparent">

                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={x:Reference Page}, Path=BindingContext.AttachCertificateFileCommand}"
                                                            CommandParameter="{Binding .}"/>
                                                    </Border.GestureRecognizers>

                                                    <HorizontalStackLayout Spacing="10"
                                                                           Padding="16,0"
                                                                           VerticalOptions="Center">

                                                        <Label Text="📎"
                                                               FontSize="17"
                                                               TextColor="#3347B8"/>

                                                        <Label Text="Attach certificate file"
                                                               FontSize="15"
                                                               TextColor="#3347B8"/>

                                                    </HorizontalStackLayout>

                                                </Border>

                                                <!-- Submit -->
                                                <Border HeightRequest="46"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 22"
                                                        BackgroundColor="#99A4DE">

                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={x:Reference Page}, Path=BindingContext.SubmitCertificateCommand}"
                                                            CommandParameter="{Binding .}"/>
                                                    </Border.GestureRecognizers>

                                                    <Label Text="Submit certificate"
                                                           FontSize="15"
                                                           FontAttributes="Bold"
                                                           TextColor="White"
                                                           HorizontalTextAlignment="Center"
                                                           VerticalTextAlignment="Center"/>

                                                </Border>

                                            </VerticalStackLayout>

                                        </Border>

                                    </VerticalStackLayout>

                                </Border>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </VerticalStackLayout>

            </Border>

        </Grid>

    </ScrollView>

</ContentPage>