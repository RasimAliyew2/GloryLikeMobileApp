<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MetanetA_MobileApp.View.SignUp.SkillsSelectionPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F3F5FA">

    <ContentPage.Resources>
        <Style x:Key="SectionCaptionStyle" TargetType="Label">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CharacterSpacing" Value="1.2" />
            <Setter Property="TextColor" Value="#667085" />
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="Label">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="TextColor" Value="#101828" />
            <Setter Property="LineBreakMode" Value="WordWrap" />
        </Style>

        <Style x:Key="SelectionCardStyle" TargetType="Border">
            <Setter Property="BackgroundColor" Value="White" />
            <Setter Property="Stroke" Value="#D9DFEA" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="StrokeShape" Value="RoundRectangle 18" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="SkillChipStyle" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#F2F4F7" />
            <Setter Property="Stroke" Value="#EAECF0" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="StrokeShape" Value="RoundRectangle 18" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16,18,16,28">

            <Border
                BackgroundColor="White"
                Stroke="#E7ECF3"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 30"
                Padding="18,18,18,24">

                <VerticalStackLayout Spacing="18">

                    <!-- Progress -->
                    <Grid ColumnDefinitions="*,*,*,*,*,*" ColumnSpacing="6">

                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4">
                            <Border BackgroundColor="#4453C7"
                                    Stroke="#4453C7"
                                    StrokeShape="RoundRectangle 13"
                                    WidthRequest="26"
                                    HeightRequest="26">
                                <Label Text="✓"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center"
                                       FontAttributes="Bold" />
                            </Border>
                            <Label Text="Identity" FontSize="12" TextColor="#4453C7" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4">
                            <Border BackgroundColor="#4453C7"
                                    Stroke="#4453C7"
                                    StrokeShape="RoundRectangle 13"
                                    WidthRequest="26"
                                    HeightRequest="26">
                                <Label Text="✓"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center"
                                       FontAttributes="Bold" />
                            </Border>
                            <Label Text="Career" FontSize="12" TextColor="#4453C7" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                            <Border BackgroundColor="#2F3FAF"
                                    Stroke="#2F3FAF"
                                    StrokeShape="RoundRectangle 14"
                                    WidthRequest="28"
                                    HeightRequest="28">
                                <Label Text="•"
                                       FontSize="22"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Border>
                            <Label Text="Skills" FontSize="12" FontAttributes="Bold" TextColor="#101828" HorizontalTextAlignment="Center" />
                            <Label Text="5 min" FontSize="11" TextColor="#667085" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="4">
                            <Border BackgroundColor="#EFF2F6"
                                    Stroke="#EFF2F6"
                                    StrokeShape="RoundRectangle 13"
                                    WidthRequest="26"
                                    HeightRequest="26">
                                <Label Text="•"
                                       TextColor="#D0D5DD"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Border>
                            <Label Text="Verify" FontSize="12" TextColor="#667085" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" Spacing="4">
                            <Border BackgroundColor="#EFF2F6"
                                    Stroke="#EFF2F6"
                                    StrokeShape="RoundRectangle 13"
                                    WidthRequest="26"
                                    HeightRequest="26">
                                <Label Text="•"
                                       TextColor="#D0D5DD"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Border>
                            <Label Text="Prefs" FontSize="12" TextColor="#667085" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="5" HorizontalOptions="Center" Spacing="4">
                            <Border BackgroundColor="#EFF2F6"
                                    Stroke="#EFF2F6"
                                    StrokeShape="RoundRectangle 13"
                                    WidthRequest="26"
                                    HeightRequest="26">
                                <Label Text="•"
                                       TextColor="#D0D5DD"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center" />
                            </Border>
                            <Label Text="Ready" FontSize="12" TextColor="#667085" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="2" Color="#EEF2F6" />

                    <!-- Back / Skip -->
                    <Grid ColumnDefinitions="Auto,* ,Auto">
                        <Label Grid.Column="0"
                               Text="‹ Back"
                               FontSize="15"
                               TextColor="#667085"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BackCommand}" />
                            </Label.GestureRecognizers>
                        </Label>

                        <Label Grid.Column="2"
                               Text="Skip for now"
                               FontSize="15"
                               TextDecorations="Underline"
                               TextColor="#667085"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SkipCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <!-- Title -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Let's map your professional strengths"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#0F172A" />

                        <Label Text="Select your role and we'll suggest the right skills."
                               FontSize="16"
                               TextColor="#667085" />
                    </VerticalStackLayout>

                    <!-- Breadcrumb -->
                    <Label IsVisible="{Binding ShowBreadcrumb}"
                           Text="{Binding BreadcrumbText, StringFormat='← {0}'}"
                           FontSize="15"
                           TextColor="#667085" />

                    <Label Text="{Binding SectionTitle}" Style="{StaticResource SectionCaptionStyle}" />

                    <ActivityIndicator
                        IsVisible="{Binding IsBusy}"
                        IsRunning="{Binding IsBusy}"
                        Color="#2F3FAF" />

                    <Label
                        IsVisible="{Binding HasError}"
                        Text="{Binding ErrorMessage}"
                        FontSize="13"
                        TextColor="#D92D20" />

                    <!-- Job Families -->
                    <CollectionView
                        IsVisible="{Binding IsJobFamilyStep}"
                        ItemsSource="{Binding JobFamilyOptions}"
                        SelectionMode="None">

                        <CollectionView.ItemsLayout>
                            <GridItemsLayout
                                Orientation="Vertical"
                                Span="2"
                                HorizontalItemSpacing="12"
                                VerticalItemSpacing="12" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource SelectionCardStyle}"
                                        MinimumHeightRequest="76">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BackgroundColor" Value="#EEF2FF" />
                                            <Setter Property="Stroke" Value="#4453C7" />
                                            <Setter Property="StrokeThickness" Value="1.5" />
                                        </DataTrigger>
                                    </Border.Triggers>

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding BindingContext.SelectJobFamilyCommand, Source={x:Reference RootPage}}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Label Text="{Binding Title}"
                                           Style="{StaticResource CardTitleStyle}"
                                           VerticalOptions="Center" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Seniorities -->
                    <CollectionView
                        IsVisible="{Binding IsSeniorityStep}"
                        ItemsSource="{Binding SeniorityOptions}"
                        SelectionMode="None">

                        <CollectionView.ItemsLayout>
                            <GridItemsLayout
                                Orientation="Vertical"
                                Span="3"
                                HorizontalItemSpacing="10"
                                VerticalItemSpacing="10" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource SelectionCardStyle}"
                                        Padding="0"
                                        HeightRequest="54">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BackgroundColor" Value="#EEF2FF" />
                                            <Setter Property="Stroke" Value="#4453C7" />
                                            <Setter Property="StrokeThickness" Value="1.5" />
                                        </DataTrigger>
                                    </Border.Triggers>

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding BindingContext.SelectSeniorityCommand, Source={x:Reference RootPage}}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Label Text="{Binding Title}"
                                           FontSize="16"
                                           TextColor="#101828"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Positions -->
                    <CollectionView
                        IsVisible="{Binding IsPositionStep}"
                        ItemsSource="{Binding PositionOptions}"
                        SelectionMode="None">

                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource SelectionCardStyle}"
                                        MinimumHeightRequest="64">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BackgroundColor" Value="#EEF2FF" />
                                            <Setter Property="Stroke" Value="#4453C7" />
                                            <Setter Property="StrokeThickness" Value="1.5" />
                                        </DataTrigger>
                                    </Border.Triggers>

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding BindingContext.SelectPositionCommand, Source={x:Reference RootPage}}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                                        <Label Grid.Column="0"
                                               Text="{Binding Title}"
                                               Style="{StaticResource CardTitleStyle}"
                                               VerticalOptions="Center" />

                                        <Label Grid.Column="1"
                                               Text="›"
                                               FontSize="20"
                                               TextColor="#98A2B3"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Skills -->
                    <VerticalStackLayout IsVisible="{Binding IsSkillStep}" Spacing="14">

                        <FlexLayout
                            BindableLayout.ItemsSource="{Binding SkillOptions}"
                            Wrap="Wrap"
                            Direction="Row"
                            AlignItems="Start">

                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource SkillChipStyle}">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BackgroundColor" Value="#ECFDF3" />
                                                <Setter Property="Stroke" Value="#12B76A" />
                                                <Setter Property="StrokeThickness" Value="1.5" />
                                            </DataTrigger>
                                        </Border.Triggers>

                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding BindingContext.ToggleSkillCommand, Source={x:Reference RootPage}}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>

                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="✓"
                                                   IsVisible="{Binding IsSelected}"
                                                   FontAttributes="Bold"
                                                   TextColor="#12B76A"
                                                   VerticalOptions="Center" />

                                            <Label Text="{Binding Skill.SkillName}"
                                                   FontSize="14"
                                                   TextColor="#101828"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>

                        <VerticalStackLayout IsVisible="{Binding HasSelectedSkills}" Spacing="10">
                            <Label Text="{Binding SelectedSkillCount, StringFormat='YOUR SKILLS ({0})'}"
                                   Style="{StaticResource SectionCaptionStyle}" />

                            <FlexLayout
                                BindableLayout.ItemsSource="{Binding SkillOptions}"
                                Wrap="Wrap"
                                Direction="Row"
                                AlignItems="Start">

                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border IsVisible="{Binding IsSelected}"
                                                BackgroundColor="#EEF2FF"
                                                Stroke="#D9E0FF"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 18"
                                                Padding="12,10"
                                                Margin="0,0,8,8">
                                            <HorizontalStackLayout Spacing="8">
                                                <Label Text="✓"
                                                       FontAttributes="Bold"
                                                       TextColor="#4453C7"
                                                       VerticalOptions="Center" />
                                                <Label Text="{Binding Skill.SkillName}"
                                                       FontSize="14"
                                                       TextColor="#4453C7"
                                                       VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>