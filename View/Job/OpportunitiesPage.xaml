<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MetanetA_MobileApp.View.Job.OpportunitiesPage"
             xmlns:controls="clr-namespace:MetanetA_MobileApp.View"
             xmlns:vm="clr-namespace:MetanetA_MobileApp.ViewModels.Job"
             xmlns:md="clr-namespace:MetanetA_MobileApp.Model"
             x:DataType="vm:OpportunitiesViewModel"
             BackgroundColor="#F6F8FC"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,34,24,90" Spacing="16">

                <VerticalStackLayout Spacing="4">
                    <Label Text="Opportunities"
                           FontSize="32"
                           FontAttributes="Bold"
                           TextColor="#071331"/>

                    <Label Text="{Binding RolesCountText}"
                           FontSize="16"
                           TextColor="#5E6678"/>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*,58"
                      ColumnSpacing="10">

                    <Border BackgroundColor="#EDF1F7"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 28"
                            HeightRequest="56">

                        <Grid ColumnDefinitions="42,*"
                              Padding="16,0">

                            <Label Text="⌕"
                                   FontSize="24"
                                   TextColor="#536071"
                                   VerticalOptions="Center"/>

                            <Entry Grid.Column="1"
                                   Text="{Binding SearchText}"
                                   Placeholder="Search roles or companies"
                                   PlaceholderColor="#8B94A5"
                                   TextColor="#071331"
                                   FontSize="16"
                                   BackgroundColor="Transparent"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            WidthRequest="56"
                            HeightRequest="56"
                            BackgroundColor="White"
                            Stroke="#DDE3ED"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 28">

                        <Label Text="☷"
                               FontSize="28"
                               TextColor="#071331"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <CollectionView ItemsSource="{Binding Opportunities}"
                                SelectionMode="None">

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="md:OpportunityItem">

                            <Border Margin="0,8,0,10"
                                    Padding="20"
                                    BackgroundColor="White"
                                    Stroke="#E2E6EF"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 28">

                                <Border.Shadow>
                                    <Shadow Brush="#CBD0DD"
                                            Offset="0,2"
                                            Radius="8"
                                            Opacity="0.35"/>
                                </Border.Shadow>

                                <VerticalStackLayout Spacing="16">

                                    <Grid ColumnDefinitions="58,*,68"
                                          ColumnSpacing="16">

                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding BindingContext.ToggleOpportunityCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                CommandParameter="{Binding .}"/>
                                        </Grid.GestureRecognizers>

                                        <Border WidthRequest="58"
                                                HeightRequest="58"
                                                BackgroundColor="#F0F3FA"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 29"
                                                VerticalOptions="Start">

                                            <Label Text="{Binding LogoLetter}"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="#071331"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="7">

                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="{Binding Company}"
                                                       FontSize="14"
                                                       TextColor="#475166"/>

                                                <Label Text="•"
                                                       FontSize="14"
                                                       TextColor="#A7AFBE"/>

                                                <Label Text="◷"
                                                       FontSize="14"
                                                       TextColor="#475166"/>

                                                <Label Text="{Binding PostedAgo}"
                                                       FontSize="14"
                                                       TextColor="#475166"/>
                                            </HorizontalStackLayout>

                                            <Label Text="{Binding Title}"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="#071331"
                                                   LineBreakMode="TailTruncation"/>

                                            <Label Text="{Binding Location}"
                                                   FontSize="15"
                                                   TextColor="#5E6678"/>

                                            <HorizontalStackLayout Spacing="8"
                                                                   Margin="0,6,0,0">

                                                <Border BackgroundColor="#EEF1FF"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 14"
                                                        Padding="10,5">
                                                    <Label Text="{Binding WorkType}"
                                                           FontSize="13"
                                                           FontAttributes="Bold"
                                                           TextColor="#263DB7"/>
                                                </Border>

                                                <Border BackgroundColor="#F0F3FA"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 14"
                                                        Padding="10,5">
                                                    <Label Text="{Binding Level}"
                                                           FontSize="13"
                                                           FontAttributes="Bold"
                                                           TextColor="#334155"/>
                                                </Border>

                                                <Border BackgroundColor="#FFEDED"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 14"
                                                        Padding="10,5">
                                                    <Label Text="{Binding Salary}"
                                                           FontSize="13"
                                                           FontAttributes="Bold"
                                                           TextColor="#FF625F"/>
                                                </Border>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Grid.Column="2"
                                                             Spacing="12"
                                                             HorizontalOptions="End">

                                            <Grid WidthRequest="58"
                                                  HeightRequest="58"
                                                  HorizontalOptions="End">

                                                <Ellipse Stroke="{Binding ScoreColor}"
                                                         StrokeThickness="6"
                                                         Fill="Transparent"/>

                                                <Label Text="{Binding Score}"
                                                       FontSize="16"
                                                       FontAttributes="Bold"
                                                       TextColor="#071331"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Grid>

                                            <Label Text="{Binding ArrowIcon}"
                                                   FontSize="24"
                                                   TextColor="#5E6678"
                                                   HorizontalOptions="End"/>
                                        </VerticalStackLayout>
                                    </Grid>

                                    <VerticalStackLayout IsVisible="{Binding IsExpanded}"
                                                         Spacing="18">

                                        <BoxView HeightRequest="1"
                                                 BackgroundColor="#E5E7EB"/>

                                        <VerticalStackLayout Spacing="8">
                                            <Label Text="ABOUT THE ROLE"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   CharacterSpacing="2"
                                                   TextColor="#5E6678"/>

                                            <Label Text="{Binding AboutRole}"
                                                   FontSize="19"
                                                   TextColor="#4B5563"
                                                   LineBreakMode="WordWrap"/>
                                        </VerticalStackLayout>

                                        <BoxView HeightRequest="1"
                                                 BackgroundColor="#E5E7EB"/>

                                        <VerticalStackLayout Spacing="8">
                                            <Label Text="RESPONSIBILITIES"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   CharacterSpacing="2"
                                                   TextColor="#5E6678"/>

                                            <Label Text="{Binding Responsibilities}"
                                                   FontSize="17"
                                                   TextColor="#4B5563"
                                                   LineBreakMode="WordWrap"/>
                                        </VerticalStackLayout>

                                        <BoxView HeightRequest="1"
                                                 BackgroundColor="#E5E7EB"/>

                                        <VerticalStackLayout Spacing="10">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <Label Text="SKILL MATCH"
                                                       FontSize="14"
                                                       FontAttributes="Bold"
                                                       CharacterSpacing="2"
                                                       TextColor="#5E6678"/>

                                                <Border Grid.Column="1"
                                                        BackgroundColor="#DDF7EC"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 14"
                                                        Padding="12,4">

                                                    <Label Text="{Binding Score, StringFormat='{0}%'}"
                                                           FontSize="16"
                                                           FontAttributes="Bold"
                                                           TextColor="#10A96D"/>
                                                </Border>
                                            </Grid>

                                            <Label Text="Matched"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   TextColor="#5E6678"/>

                                            <Label Text="{Binding MatchedSkills}"
                                                   FontSize="16"
                                                   TextColor="#10A96D"
                                                   LineBreakMode="WordWrap"/>

                                            <Label Text="Missing"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   TextColor="#5E6678"/>

                                            <Border BackgroundColor="#FFE8EA"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 14"
                                                    Padding="10,5"
                                                    HorizontalOptions="Start">

                                                <Label Text="{Binding MissingSkills}"
                                                       FontSize="15"
                                                       FontAttributes="Bold"
                                                       TextColor="#EF4444"/>
                                            </Border>

                                            <Border BackgroundColor="Transparent"
                                                    StrokeThickness="0"
                                                    Padding="12,8">

                                                <Grid ColumnDefinitions="4,*"
                                                      ColumnSpacing="14">

                                                    <BoxView BackgroundColor="#7C8DEB"
                                                             WidthRequest="4"/>

                                                    <Label Grid.Column="1"
                                                           Text="{Binding MatchNote}"
                                                           FontSize="16"
                                                           FontAttributes="Italic"
                                                           TextColor="#5E6678"
                                                           LineBreakMode="WordWrap"/>
                                                </Grid>
                                            </Border>
                                        </VerticalStackLayout>

                                        <BoxView HeightRequest="1"
                                                 BackgroundColor="#E5E7EB"/>

                                        <Grid ColumnDefinitions="*,*,58"
                                              ColumnSpacing="12">

                                            <Border BackgroundColor="White"
                                                    Stroke="#E2E6EF"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 24"
                                                    HeightRequest="50">

                                                <Label Text="Full details"
                                                       FontSize="16"
                                                       FontAttributes="Bold"
                                                       TextColor="#303744"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    BackgroundColor="#4D3AD7"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 24"
                                                    HeightRequest="50">

                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding BindingContext.ApplyCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                        CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>

                                                <Label Text="Apply"
                                                       FontSize="17"
                                                       FontAttributes="Bold"
                                                       TextColor="White"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Border>

                                            <Border Grid.Column="2"
                                                    BackgroundColor="White"
                                                    Stroke="#E2E6EF"
                                                    StrokeThickness="1"
                                                    StrokeShape="RoundRectangle 25"
                                                    HeightRequest="50"
                                                    WidthRequest="58">

                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding BindingContext.ToggleSaveCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                                        CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>

                                                <Label Text="{Binding SaveIcon}"
                                                       FontSize="28"
                                                       TextColor="{Binding SaveColor}"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Border>
                                        </Grid>
                                    </VerticalStackLayout>

                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <controls:BottomMenu Grid.Row="1"
                             VerticalOptions="End"
                             Margin="0,0,0,6"/>
    </Grid>
</ContentPage>