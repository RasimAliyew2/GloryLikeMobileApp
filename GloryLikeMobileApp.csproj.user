      <SubType>Designer</SubType>
    </MauiXaml>
    <MauiXaml Update="View\Profile\SkillsPage.xaml">
      <SubType>Designer</SubType>
    </MauiXaml>
    <MauiXaml Update="View\SignUp\CareerExperiencePage.xaml">
      <SubType>Designer</SubType>
    </MauiXaml>
    <MauiXaml Update="View\SignUp\SkillsSelectionPage.xaml">
      <SubType>Designer</SubType>
    </MauiXaml>
    <MauiXaml Update="View\SignUp\VerifySkillsPage.xaml">
      <SubType>Designer</SubType>
    </MauiXaml>
    <MauiXaml Update="View\SignUp\VerifyIdentityPage.xaml">
